{
    "name": "resume-analyze",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "pnpm run build:client",
        "build:client": "vite build",
        "dev": "wrangler dev",
        "dev:local": "tsx src/local/devServer.ts",
        "deploy": "wrangler deploy",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "oxlint . --react-plugin --jsx-a11y-plugin --vitest-plugin -D correctness -W suspicious -W perf -A react-in-jsx-scope && node scripts/check-xstate-links.mjs",
        "test": "pnpm run test:api && pnpm run test:browser",
        "test:api": "vitest run --config vitest.config.ts && vitest run --config vitest.workers.config.mts",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:e2e": "playwright test",
        "start": "wrangler dev",
        "typecheck": "tsc --noEmit",
        "cf-typegen": "wrangler types"
    },
    "dependencies": {
        "@stylexjs/stylex": "^0.19.0",
        "@xstate/react": "^6.1.0",
        "arktype": "^2.2.1",
        "express": "^5.2.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router-dom": "^7.18.0",
        "swr": "^2.4.2",
        "xstate": "^5.32.2"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.16.19",
        "@playwright/test": "^1.61.1",
        "@stylexjs/rollup-plugin": "^0.19.0",
        "@tailwindcss/vite": "^4.3.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.4",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/browser": "^4.1.9",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "^4.1.9",
        "daisyui": "^5.5.23",
        "jsdom": "^29.1.1",
        "oxlint": "^1.71.0",
        "playwright": "^1.61.1",
        "prettier": "^3.8.4",
        "start-server-and-test": "^3.0.11",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.1.0",
        "vitest": "^4.1.9",
        "wait-on": "^9.0.10",
        "wrangler": "^4.104.0"
    }
}
