/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "resume-analyze",
    "main": "src/index.ts",
    "compatibility_date": "2026-06-26",
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
    },
    "upload_source_maps": true,
    "compatibility_flags": ["nodejs_compat"],
    "routes": [
        {
            "pattern": "rs.lqxclqxc.biz",
            "custom_domain": true,
        },
    ],
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application",
        "run_worker_first": ["/api/*"],
    },
    "build": {
        "command": "pnpm run build:client",
    },
    "durable_objects": {
        "bindings": [
            {
                "name": "RESUME_REGISTRY",
                "class_name": "ResumeRegistryObject",
            },
            {
                "name": "RESUME_DOCUMENT",
                "class_name": "ResumeDocumentObject",
            },
            {
                "name": "JD_STORE",
                "class_name": "JobDescriptionStoreObject",
            },
        ],
    },
    "queues": {
        "producers": [
            {
                "binding": "RESUME_ANALYSIS_QUEUE",
                "queue": "resume-analysis-jobs",
            },
        ],
        "consumers": [
            {
                "queue": "resume-analysis-jobs",
                "max_batch_size": 1,
                "max_batch_timeout": 5,
                "max_retries": 3,
                "dead_letter_queue": "resume-analysis-jobs-dlq",
            },
        ],
    },
    "migrations": [
        {
            "tag": "v1",
            "new_sqlite_classes": [
                "ResumeObject",
                "ResumeIndexObject",
                "JobDescriptionObject",
                "JobDescriptionIndexObject",
            ],
        },
        {
            "tag": "v2",
            "new_sqlite_classes": [
                "ResumeRegistryObject",
                "ResumeDocumentObject",
                "JobDescriptionStoreObject",
            ],
        },
    ],
    "ai": {
        "binding": "AI",
        "remote": true,
    },
    "vars": {
        "AI_GATEWAY_ID": "collects-auto-ai",
        "GEMINI_MODEL": "gemini-3.5-flash",
    },
    /**
     * Smart Placement
     * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
     */
    // "placement": {  "mode": "smart" }
    /**
     * Bindings
     * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
     * databases, object storage, AI inference, real-time communication and more.
     * https://developers.cloudflare.com/workers/runtime-apis/bindings/
     */
    /**
     * Environment Variables
     * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
     * Note: Use secrets to store sensitive data.
     * https://developers.cloudflare.com/workers/configuration/secrets/
     */
    // "vars": {  "MY_VARIABLE": "production_value" }
    /**
     * Static Assets
     * https://developers.cloudflare.com/workers/static-assets/binding/
     */
    // "assets": {  "directory": "./public/",  "binding": "ASSETS" }
    /**
     * Service Bindings (communicate between multiple Workers)
     * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
     */
    // "services": [  {   "binding": "MY_SERVICE",   "service": "my-service"  } ]
}
